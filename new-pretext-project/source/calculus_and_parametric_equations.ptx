    <exercise xml:id="sec10-3-concept-sata-02" label="sec10-3-concept-sata-02">
      <title>Exercise: Horizontal and vertical tangents.</title>
    <statement>
      <p>
        Select all true statements about tangent lines to parametric curves.
      </p>
    </statement>

    <choices randomize="yes">
      <choice correct="yes">
        <statement><p>If <m>\dfrac{dy}{dt}=0</m> and <m>\dfrac{dx}{dt}\neq 0</m>, then the tangent line is horizontal.</p></statement>
        <feedback><p>Correct.</p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p>If <m>\dfrac{dx}{dt}=0</m> and <m>\dfrac{dy}{dt}\neq 0</m>, then the tangent line is vertical.</p></statement>
        <feedback><p>Correct.</p></feedback>
      </choice>
      <choice correct="no">
        <statement><p>If <m>\dfrac{dy}{dt}=0</m>, then the particle is not moving.</p></statement>
        <feedback><p>The particle may still be moving horizontally.</p></feedback>
      </choice>
      <choice correct="no">
        <statement><p>If <m>\dfrac{dx}{dt}=0</m>, then the tangent line must be horizontal.</p></statement>
        <feedback><p>This is the condition associated with a vertical tangent, provided <m>\dfrac{dy}{dt}\neq 0</m>.</p></feedback>
      </choice>
      <choice correct="yes">
        <statement><p>A particle can be moving even when the tangent line is horizontal.</p></statement>
        <feedback><p>Correct. The horizontal component of velocity may be nonzero.</p></feedback>
      </choice>
    </choices>
  </exercise>

